# OMNITECH SIEM — stack Docker · secrets (copier en .env, ne PAS versionner)
# ---------------------------------------------------------------------------
# Secret de chiffrement Graylog (>= 64 caracteres aleatoires, FIXE dans le temps).
#   generer :  openssl rand -hex 48
GRAYLOG_PASSWORD_SECRET=CHANGEME_64_caracteres_minimum

# SHA-256 du mot de passe de l'admin Graylog.
#   generer :  echo -n 'MonMotDePasseAdmin' | sha256sum | cut -d' ' -f1
GRAYLOG_ROOT_PASSWORD_SHA2=CHANGEME_sha256_du_mot_de_passe

# URI telle que vue depuis le navigateur (mettre l'IP/FQDN reel + reverse proxy TLS).
GRAYLOG_HTTP_EXTERNAL_URI=http://127.0.0.1:9000/

# Heap OpenSearch : ~50 % de la RAM allouee au conteneur, plafond ~31g.
OS_HEAP=2g
