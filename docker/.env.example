# OMNITECH SIEM — stack Docker · secrets & paramètres (copier en .env, ne PAS versionner)
# ===========================================================================================
# --- Graylog ---
# Secret de chiffrement Graylog (>= 64 caractères aléatoires, FIXE dans le temps).
#   openssl rand -hex 48
GRAYLOG_PASSWORD_SECRET=CHANGEME_64_caracteres_minimum
# SHA-256 du mot de passe de l'admin Graylog.
#   echo -n 'MonMotDePasseAdmin' | sha256sum | cut -d' ' -f1
GRAYLOG_ROOT_PASSWORD_SHA2=CHANGEME_sha256_du_mot_de_passe
# URI vue depuis le navigateur (passe par nginx en HTTPS).
GRAYLOG_HTTP_EXTERNAL_URI=https://omni-siem.local/

# --- Console SOC (/m/api, /soc, /m) ---
# Secret HMAC des sessions de la console (FIXE, sinon déconnexions).  openssl rand -hex 32
MOBILE_SECRET=CHANGEME_secret_session_console
# Secret du webhook push Graylog->console (optionnel ; défaut = MOBILE_SECRET).
MOBILE_PUSH_SECRET=
# Pseudonymisation des captures (0 = clair, 1 = rédigé).
MOBILE_REDACT=0
# Push web (optionnel) : clé publique VAPID (base64url). Laisser vide pour désactiver le push.
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:soc@omnitech-security.fr

# --- nginx / TLS ---
# Nom servi (CN du certificat auto-signé généré au 1er démarrage ; remplacer par un vrai cert en prod).
SERVER_NAME=omni-siem.local

# --- Dimensionnement / scalabilité ---
OS_HEAP=2g            # heap OpenSearch (~50 % de la RAM du conteneur, max ~31g)
GRAYLOG_MEM=3g        # limite mémoire conteneur Graylog
GL_HEAP=2g            # heap JVM Graylog (-Xms/-Xmx)
GL_PROC=4             # processbuffer_processors (somme proc+out+in <= vCPU)
GL_OUT=3              # outputbuffer_processors
GL_IN=2               # inputbuffer_processors
GL_BATCH=1000         # output_batch_size (débit OpenSearch)
GL_JOURNAL=10gb       # taille max du journal disque (tampon d'ingestion)
MONGO_CACHE_GB=1      # cache WiredTiger MongoDB (sinon ~50 % RAM hôte)

# --- Collecteurs OPTIONNELS (non montés par défaut) ---
# Les fetchers M365/ESET/EMS et l'export SMB sont des add-ons de collecte, déployés
# séparément. Si containerisés, fournir ici : M365_TENANT/CLIENT_ID/SECRET, ESET_*,
# EMS_*, SMB_* , BACKUP_PASSPHRASE. Le cœur SIEM (Graylog+console+nginx) n'en a pas besoin.
