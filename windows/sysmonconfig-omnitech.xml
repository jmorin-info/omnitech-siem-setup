<!--
  sysmonconfig-omnitech.xml - Configuration Sysmon de demarrage (compacte)
  =========================================================================
  Philosophie : capter ce qui sert a la detection, exclure le bruit evident.
  Schema 4.50 : compatible Sysmon v13 a v15+.
  Pour aller plus loin : basculer sur sysmon-modular (Olaf Hartong) en gardant
  les memes canaux cote Winlogbeat - aucun autre changement necessaire.
  Mise a jour de la config :  Sysmon64.exe -c sysmonconfig-omnitech.xml
-->
<Sysmon schemaversion="4.50">
  <HashAlgorithms>SHA256,IMPHASH</HashAlgorithms>
  <ArchiveDirectory>SysmonQuarantine</ArchiveDirectory>
  <EventFiltering>

    <!-- EID 1 : creation de processus. Tout, sauf bruit massif connu. -->
    <RuleGroup name="" groupRelation="or">
      <ProcessCreate onmatch="exclude">
        <Image condition="is">C:\Windows\System32\svchost.exe</Image>
        <Image condition="is">C:\Windows\System32\wbem\WmiPrvSE.exe</Image>
        <Image condition="begin with">C:\Program Files\ESET\</Image>
        <Image condition="begin with">C:\Program Files (x86)\NinjaRMMAgent\</Image>
        <CommandLine condition="begin with">C:\Windows\system32\DllHost.exe /Processid</CommandLine>
      </ProcessCreate>
    </RuleGroup>

    <!-- EID 3 : connexions reseau des binaires a risque uniquement (anti-bruit) -->
    <RuleGroup name="" groupRelation="or">
      <NetworkConnect onmatch="include">
        <Image condition="image">powershell.exe</Image>
        <Image condition="image">pwsh.exe</Image>
        <Image condition="image">cmd.exe</Image>
        <Image condition="image">wscript.exe</Image>
        <Image condition="image">cscript.exe</Image>
        <Image condition="image">mshta.exe</Image>
        <Image condition="image">rundll32.exe</Image>
        <Image condition="image">regsvr32.exe</Image>
        <Image condition="image">certutil.exe</Image>
        <Image condition="image">bitsadmin.exe</Image>
        <Image condition="image">curl.exe</Image>
        <Image condition="image">msiexec.exe</Image>
        <DestinationPort condition="is">3389</DestinationPort>
        <DestinationPort condition="is">4444</DestinationPort>
        <DestinationPort condition="is">5985</DestinationPort>
      </NetworkConnect>
    </RuleGroup>

    <!-- EID 5 : fin de processus - inutile, off -->
    <ProcessTerminate onmatch="include" />

    <!-- EID 6 : drivers non Microsoft/Intel -->
    <RuleGroup name="" groupRelation="or">
      <DriverLoad onmatch="exclude">
        <Signature condition="contains">Microsoft</Signature>
        <Signature condition="contains">Windows</Signature>
        <Signature condition="contains">Intel</Signature>
      </DriverLoad>
    </RuleGroup>

    <!-- EID 7 : DLL sensibles (vol de credentials) chargees hors processus systeme -->
    <RuleGroup name="" groupRelation="or">
      <ImageLoad onmatch="include">
        <ImageLoaded condition="end with">samlib.dll</ImageLoaded>
        <ImageLoaded condition="end with">vaultcli.dll</ImageLoaded>
        <ImageLoaded condition="end with">wlanapi.dll</ImageLoaded>
        <ImageLoaded condition="end with">dsquery.dll</ImageLoaded>
      </ImageLoad>
    </RuleGroup>

    <!-- EID 8 : injection de thread distant (hors AV) -->
    <RuleGroup name="" groupRelation="or">
      <CreateRemoteThread onmatch="exclude">
        <SourceImage condition="begin with">C:\Program Files\ESET\</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\csrss.exe</SourceImage>
      </CreateRemoteThread>
    </RuleGroup>

    <!-- EID 10 : acces a LSASS (Mimikatz & co), AV/EDR exclus -->
    <RuleGroup name="" groupRelation="or">
      <ProcessAccess onmatch="include">
        <TargetImage condition="is">C:\Windows\System32\lsass.exe</TargetImage>
      </ProcessAccess>
    </RuleGroup>
    <RuleGroup name="" groupRelation="or">
      <ProcessAccess onmatch="exclude">
        <SourceImage condition="begin with">C:\Program Files\ESET\</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\svchost.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\wbem\WmiPrvSE.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\MsMpEng.exe</SourceImage>
        <GrantedAccess condition="is">0x1000</GrantedAccess>
        <GrantedAccess condition="is">0x1400</GrantedAccess>
        <GrantedAccess condition="is">0x101400</GrantedAccess>
        <GrantedAccess condition="is">0x101000</GrantedAccess>
      </ProcessAccess>
    </RuleGroup>

    <!-- EID 11 : creations de fichiers a risque -->
    <RuleGroup name="" groupRelation="or">
      <FileCreate onmatch="include">
        <TargetFilename condition="contains">\Startup\</TargetFilename>
        <TargetFilename condition="contains">\Start Menu\Programs\Startup</TargetFilename>
        <TargetFilename condition="end with">.exe</TargetFilename>
        <TargetFilename condition="end with">.dll</TargetFilename>
        <TargetFilename condition="end with">.ps1</TargetFilename>
        <TargetFilename condition="end with">.bat</TargetFilename>
        <TargetFilename condition="end with">.vbs</TargetFilename>
        <TargetFilename condition="end with">.hta</TargetFilename>
        <TargetFilename condition="end with">.lnk</TargetFilename>
      </FileCreate>
    </RuleGroup>

    <!-- EID 12/13/14 : persistance registre -->
    <RuleGroup name="" groupRelation="or">
      <RegistryEvent onmatch="include">
        <TargetObject condition="contains">\CurrentVersion\Run</TargetObject>
        <TargetObject condition="contains">\CurrentVersion\RunOnce</TargetObject>
        <TargetObject condition="contains">\Image File Execution Options\</TargetObject>
        <TargetObject condition="contains">\CurrentControlSet\Services\</TargetObject>
        <TargetObject condition="contains">\Winlogon\Shell</TargetObject>
        <TargetObject condition="contains">\Winlogon\Userinit</TargetObject>
        <TargetObject condition="contains">\Policies\System\</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <!-- EID 15 : flux ADS (fichiers telecharges/marques) -->
    <RuleGroup name="" groupRelation="or">
      <FileCreateStreamHash onmatch="include">
        <TargetFilename condition="contains">Downloads</TargetFilename>
        <TargetFilename condition="end with">.exe</TargetFilename>
        <TargetFilename condition="end with">.ps1</TargetFilename>
      </FileCreateStreamHash>
    </RuleGroup>

    <!-- EID 17/18 : named pipes offensifs classiques -->
    <RuleGroup name="" groupRelation="or">
      <PipeEvent onmatch="include">
        <PipeName condition="contains">psexe</PipeName>
        <PipeName condition="contains">paexec</PipeName>
        <PipeName condition="contains">remcom</PipeName>
        <PipeName condition="contains">msagent_</PipeName>
        <PipeName condition="contains">postex_</PipeName>
      </PipeEvent>
    </RuleGroup>

    <!-- EID 19/20/21 : persistance WMI - tout -->
    <RuleGroup name="" groupRelation="or">
      <WmiEvent onmatch="exclude" />
    </RuleGroup>

    <!-- EID 22 : requetes DNS, domaines tres frequents exclus -->
    <RuleGroup name="" groupRelation="or">
      <DnsQuery onmatch="exclude">
        <QueryName condition="end with">.omnitech.security</QueryName>
        <QueryName condition="end with">.microsoft.com</QueryName>
        <QueryName condition="end with">.windowsupdate.com</QueryName>
        <QueryName condition="end with">.windows.com</QueryName>
        <QueryName condition="end with">.office.com</QueryName>
        <QueryName condition="end with">.office365.com</QueryName>
        <QueryName condition="end with">.live.com</QueryName>
        <QueryName condition="end with">.eset.com</QueryName>
        <QueryName condition="end with">.in-addr.arpa</QueryName>
        <QueryName condition="end with">.local</QueryName>
      </DnsQuery>
    </RuleGroup>

    <!-- EID 25 : process tampering (hollowing/herpaderping) - tout -->
    <RuleGroup name="" groupRelation="or">
      <ProcessTampering onmatch="exclude" />
    </RuleGroup>

  </EventFiltering>
</Sysmon>
