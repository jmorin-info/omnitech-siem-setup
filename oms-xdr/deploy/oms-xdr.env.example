# /etc/oms-xdr/oms-xdr.env  (chmod 600, propriétaire root) — OPTIONNEL
# Secrets OMS-XDR — ne jamais committer. Idéalement injectés depuis Vaultwarden.
# La lecture passe par OpenSearch local (aucun token Graylog requis) et le blocage
# FortiGate est délégué au feed omni-soar (aucun token FortiGate requis).
#
# Renseigner uniquement si les fonctions correspondantes sont activées :
OMS_TEAMS_WEBHOOK=          # notification Teams (teams.enabled: true)
OMS_NINJA_URL=             # actionneur NinjaOne (isolate) — futur
OMS_NINJA_CLIENT_ID=
OMS_NINJA_SECRET=
