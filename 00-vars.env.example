# 00-vars.env.example — MODELE. Copier en 00-vars.env (chmod 600) puis renseigner.
# Les valeurs "CHANGEME" sont des SECRETS a definir localement (jamais versionnes).
# Les valeurs structurelles (IP/ports/heaps) sont conservees a titre indicatif.

# ==============================================================================
# OMNITECH Security - Stack SIEM Graylog (bx-it-graylog-vm / 10.33.220.10)
# Variables globales sourcees par tous les scripts 01-09
#
#   !!! chmod 600 00-vars.env : ce fichier contient des secrets !!!
#
# Lignes marquees "A VERIFIER" : a controler avant de lancer quoi que ce soit.
# ==============================================================================

## ---- Identite machine -------------------------------------------------------
SIEM_HOSTNAME="bx-it-graylog-vm"
SIEM_DOMAIN="omnitech.security"
SIEM_FQDN="${SIEM_HOSTNAME}.${SIEM_DOMAIN}"

## ---- Reseau (VLAN 220) ------------------------------------------------------
SIEM_IP="10.33.220.10"
SIEM_PREFIX="24"
SIEM_GW="10.33.220.254"          # A VERIFIER : IP du FortiGate sur le VLAN 220
SIEM_IFACE="eno1"                # detecte par le preflight (etait ens18)
APPLY_NETWORK="0"                # 1 = le script 01 ecrit la conf reseau statique
                                 # 0 = il affiche seulement le bloc a copier (reseau deja OK ici)
DNS1="10.33.50.250"              # BX-AD-01-IT-VM
DNS2="10.33.50.251"              # A VERIFIER : BX-AD02-IT-VM
NTP1="10.33.50.250"              # PDC emulator = source de temps de reference
NTP2="10.33.50.251"

## ---- Sous-reseaux autorises (pare-feu local nftables) -----------------------
NET_ADMIN="10.33.0.0/16"         # SSH + console web. A restreindre au VLAN d'admin si possible
NET_BEATS="10.33.0.0/16"         # VLANs postes/serveurs emettant Winlogbeat (TCP 5044)
IP_FAZ="10.33.80.253"            # FortiAnalyzer (log forwarding syslog/CEF)
VSPHERE_NET="10.33.0.0/16"          # A RESTREINDRE au VLAN management ESXi/vCenter (syslog TCP 1516)
IP_CENTREON="10.33.50.6"                   # IP du poller Centreon (vide = pas de regle SNMP)

## ---- Secrets (repris de l'existant - a faire tourner si souhaite) -----------
GRAYLOG_ADMIN_PASS=CHANGEME
MONGO_ADMIN_PASS=CHANGEME
MONGO_GRAYLOG_PASS=CHANGEME
# Exige par le paquet opensearch >= 2.12 a l'installation ; devient inutile ensuite
# car on desactive le plugin de securite (OpenSearch ecoute uniquement en localhost).
OPENSEARCH_BOOTSTRAP_PASS=CHANGEME

## ---- Teams (canal SOC) -------------------------------------------------------
# URL du webhook entrant Teams (Workflows / Power Automate) :
#   Teams > canal dedie > ... > Workflows > "Publier dans un canal lorsqu'une
#   demande de webhook est recue" > copier l'URL (https://...logic.azure.com/...)
# Laisser vide = pas de notification Teams. Puis relancer 13-graylog-alerts.sh.
TEAMS_WEBHOOK_URL=CHANGEME

## ---- SMTP interne (notifications d'alertes Graylog) -------------------------
SMTP_RELAY="smtp-internal.omnitech-security.fr"
SMTP_PORT="25"
SMTP_FROM="no-reply@omnitech-security.fr"
ALERT_EMAIL="informatique@omnitech-security.fr"   # destinataire des notifications d'alertes (script 10)

## ---- SNMPv3 pour Centreon (script 09, optionnel) ----------------------------
SNMP_V3_USER="centreon"
SNMP_V3_AUTH_PASS=CHANGEME
SNMP_V3_PRIV_PASS=CHANGEME

## ---- Dimensionnement (base VM 8 vCPU / 32 Go RAM) ---------------------------
OS_HEAP="12g"                    # heap OpenSearch (~1/3 RAM VM, jamais > 31g)
GL_HEAP="4g"                     # heap Graylog
MONGO_CACHE_GB="1"               # cache WiredTiger. Sans ca Mongo prend ~50% de la RAM !
JOURNAL_SIZE="10gb"              # journal disque Graylog = tampon si OpenSearch est down

## ---- Stockage ----------------------------------------------------------------
# Disques de la machine :
#   sda 7,3T  = grand disque VIERGE          -> donnees (OpenSearch + journal Graylog)
#   sdb 931G  = disque systeme (/, /var 21G, /home 818G, swap)
#   sdc 114G  = AMOVIBLE (cle USB exfat) -> NE PAS TOUCHER, a debrancher idealement
DATA_DISK="/dev/sda"             # formate XFS et monte sur DATA_MOUNT (donnees detruites !)
DATA_MOUNT="/data"               # OpenSearch -> /data/opensearch ; journal Graylog -> /data/graylog-journal
                                 # (evite de saturer /var qui ne fait que 21,6 Go)
BACKUP_DIR="/home/siem-backup"   # sur sdb (818 Go libres) : separation physique des sauvegardes vs donnees (sda)
RETENTION_DAYS="14"              # retention locale des sauvegardes

## ---- Microsoft 365 / Entra ID (app OMNI-SIEM-Collector, cf. M365.md) --------
M365_TENANT_ID=CHANGEME
M365_CLIENT_ID=CHANGEME
M365_CLIENT_SECRET=CHANGEME

# Passphrase chiffrement des sauvegardes config (A COPIER DANS LE
# COFFRE-FORT : sans elle, les archives sont irrecuperables)
BACKUP_PASSPHRASE=CHANGEME

# --- LDAPS console Graylog (33-ldaps-auth.sh) --------------------------------
LDAP_HOST='bx-ad-01-it-vm.omnitech.security'
LDAP_BIND_DN='svc_siem@omnitech.security'
LDAP_BIND_PASS=CHANGEME
LDAP_REQUIRED_GROUP_DN='CN=Admins du domaine,OU=Comptes_Service,OU=_Support,OU=Entreprise,DC=omnitech,DC=security'

# --- Rapport hebdomadaire (34-weekly-report.sh / omni-weekly-report) ---------
REPORT_RECIPIENTS='informatique@omnitech-security.fr'
REPORT_FROM='no-reply@omnitech-security.fr'
REPORT_SMTP='smtp-internal.omnitech-security.fr'
REPORT_SMTP_PORT='25'

# --- SOAR-light : blocage auto d'IP attaquantes (36-soar.sh / omni-soar) -----
SOAR_TTL_HOURS='24'
SOAR_MAX='500'
SOAR_WHITELIST='159.180.234.120,92.184.107.14,92.184.96.118,81.255.193.131'
SOAR_MIN_HITS='5'

# --- Supervision collecte : couverture SLA + go-dark (39 / omni-collect-health)
# COLLECT_GO_DARK_HOURS : hote gere muet > N h = go-dark (tolere une nuit + marge)
# COLLECT_MANAGED_DAYS  : hote muet > N j = decommissionne (sorti du calcul SLA)
COLLECT_GO_DARK_HOURS='26'
COLLECT_MANAGED_DAYS='14'

# --- Carte cyber temps reel (42-carte-cyber.sh / omni-geo-flux) --------------
# GEO_HQ_LAT/LON/NAME : point de destination des arcs (siege / datacenter)
# GEO_FLUX_WINDOW_MIN : fenetre glissante d'agregation ; GEO_FLUX_MAX : nb d'arcs
GEO_HQ_LAT='44.88'
GEO_HQ_LON='-0.55'
GEO_HQ_NAME='OMNITECH (Bordeaux)'
GEO_FLUX_WINDOW_MIN='10'
GEO_FLUX_MAX='160'

# --- Detection de scan reseau (48-ndr-scan.sh / omni-ndr-scan) ---------------
# SCAN_WINDOW_M : fenetre (min) ; SCAN_HOST_MIN : dest_ip distincts -> horizontal
# SCAN_PORT_MIN : dest_port distincts -> vertical (sur <= SCAN_VERT_MAXHOSTS hotes)
SCAN_WINDOW_M='60'
SCAN_HOST_MIN='30'
SCAN_PORT_MIN='25'
# SCAN_ALLOW_SRC : IP d'infra de supervision (NMS/sondes) qui balaient le parc par nature
# (faux "scan horizontal"). CSV. Ne PAS y mettre de DC/serveur applicatif (garder le signal).
SCAN_ALLOW_SRC=''

# --- omni-ndr-beacon : whitelist d'appareils benins (trafic regulier PAR NATURE) -
# IP SOURCE a exclure du beaconing (qualifies FP) : 10.33.30.2/.5 = telephonie VoIP
# (SIP 5060 / STUN 3478), 10.33.60.15 (DOM-TEST-VIDEO) = systeme video (poll port 4000).
NDR_BEACON_WHITELIST_SRC='10.33.30.2,10.33.30.5,10.33.60.15'

# --- omni-ndr-exfil : exfiltration par VOLUME (FortiGate bytes_sent) ---------
# EXFIL_WINDOW_M (min), EXFIL_BYTES_GB (seuil Go), EXFIL_TOP (couples examines),
# EXFIL_ALLOW_DEST (IP egress legitimes, ex egress HTTPS du SIEM), EXFIL_ALLOW_SRC.
EXFIL_WINDOW_M='60'
EXFIL_BYTES_GB='1'
EXFIL_TOP='50'
EXFIL_ALLOW_DEST='160.79.104.10'
EXFIL_ALLOW_SRC=''

# --- Nouvelles sources de logs (52-new-sources.sh) --------------------------
IP_ESET='10.33.50.20'          # ESET PROTECT -> syslog TCP (514 redirige vers 1515)
IP_NPS='10.33.50.247'          # Windows NPS (RADIUS) -> Winlogbeat (Security 6272-6274)
IP_BUNKERWEB='10.33.70.1'      # BunkerWeb (WAF Debian) -> Filebeat vers Beats 5044
ESET_PORT='1515'               # port d'ecoute reel cote SIEM (514 redirige -> 1515)
IP_EMS='10.33.80.15'           # FortiClient EMS -> syslog-over-TLS TCP (514 redirige vers 1518)
EMS_PORT='1518'                # port d'ecoute reel cote SIEM (514 redirige -> 1518, input TLS)

# FortiGate DHCP (collecteur omni-fortidhcp-fetch) - cle API lecture seule (svc-siem-ro)
FORTI_DHCP_HOST='10.33.220.254'
FORTI_DHCP_TOKEN=CHANGEME
FORTI_DHCP_PORT='4443'
